{
  "cli": {
    "version": ">= 16.0.0"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "autoIncrement": true,
      "ios": {
        "buildConfiguration": "Release"
      }
    }
  },
  "submit": {
    "production": {
      "ios": {
        "appleId": "SINUN_APPLE_ID@email.com",
        "ascAppId": "APPSTORE_CONNECT_APP_ID",
        "appleTeamId": "APPLE_TEAM_ID",
        "language": "en-US"
      }
    }
  }
}
